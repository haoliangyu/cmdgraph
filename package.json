{
  "name": "doclix",
  "version": "0.1.0",
  "description": "CLI documentation introspection tool for AI agents",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "doclix": "bin/run.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "doclix": "npm run build && node ./dist/index.js",
    "build": "tsc -p tsconfig.json",
    "build:docs": "npm run build && node ./dist/index.js generate \"node ./dist/index.js\" --format=html --format=llms-txt --format=sitemap --site-base-url=https://haoliangyu.github.io/doclix/ --root-command-name=doclix --output=./docs",
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run build && vitest run --exclude test/e2e/**/*.test.ts",
    "test:watch": "vitest",
    "prepare": "husky",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "npm run build && vitest run test/e2e"
  },
  "keywords": [
    "cli",
    "documentation",
    "introspection",
    "oclif"
  ],
  "license": "MIT",
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "execa": "^9.5.2",
    "p-limit": "^7.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "oclif": {
    "bin": "doclix",
    "commands": "./dist/commands"
  },
  "publishConfig": {
    "access": "public"
  }
}
